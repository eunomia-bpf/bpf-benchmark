# BpfReJIT kernel config fragment
# Merge with defconfig via: scripts/kconfig/merge_config.sh .config this_file

# === BPF core ===
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y

# === BTF (kfunc/kinsn required) ===
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y

# === Module support ===
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# === Ftrace / trampoline ===
CONFIG_FTRACE=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FUNCTION_TRACER=y

# === Networking (e2e tests) ===
CONFIG_VETH=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_CLS_ACT=y
CONFIG_XDP_SOCKETS=y
CONFIG_BRIDGE=y
CONFIG_TUN=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_NET_SCH_BPF=y

# === BPF prog types ===
CONFIG_CGROUP_BPF=y
CONFIG_BPF_LSM=y
CONFIG_BPF_EVENTS=y
CONFIG_SECURITY=y

# === Cgroup ===
CONFIG_CGROUPS=y
CONFIG_CGROUP_NET_CLASSID=y

# === sched_ext (scx e2e) ===
CONFIG_SCHED_CLASS_EXT=y

# === VM support (virtme-ng) ===
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_9P_FS=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_OVERLAY_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y

# === Performance / debug ===
CONFIG_PERF_EVENTS=y

# === Reduce scheduling noise for benchmarks ===
CONFIG_PREEMPT_NONE=y
