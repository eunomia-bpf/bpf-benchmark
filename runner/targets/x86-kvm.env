TARGET_ARCH=x86_64
TARGET_EXECUTOR=kvm
TARGET_SUPPORTS_SCHED_EXT=1
TARGET_KVM_BACKEND=vng
TARGET_KVM_EXECUTABLE=runner/scripts/vng-wrapper.py
TARGET_KVM_HOST_PYTHON_DEFAULT=python3
TARGET_REMOTE_PYTHON_DEFAULT=python3
TARGET_GUEST_PACKAGE_MANAGER=apt
TARGET_KVM_KERNEL_IMAGE_DEFAULT=.cache/x86-kernel-build/arch/x86/boot/bzImage
TARGET_KVM_TEST_CPUS_SPEC=auto:0.8
TARGET_KVM_TEST_MEM=16G
TARGET_KVM_BENCH_CPUS_SPEC=4
TARGET_KVM_BENCH_MEM=16G
