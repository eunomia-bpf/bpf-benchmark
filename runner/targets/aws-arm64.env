TARGET_ARCH=arm64
TARGET_EXECUTOR=aws-ssh
TARGET_AWS_ENV_PREFIX=AWS_ARM64
TARGET_NAME_TAG_DEFAULT=bpf-benchmark-arm64
TARGET_INSTANCE_TYPE_DEFAULT=t4g.micro
TARGET_TEST_INSTANCE_TYPE_DEFAULT=t4g.micro
TARGET_BENCH_INSTANCE_TYPE_DEFAULT=t4g.medium
TARGET_REMOTE_USER_DEFAULT=ec2-user
TARGET_REMOTE_PYTHON_DEFAULT=python3
TARGET_REMOTE_STAGE_DIR_DEFAULT=/var/tmp/bpf-benchmark-aws-arm64
TARGET_AMI_PARAM_DEFAULT=/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-arm64
TARGET_AWS_REGION_DEFAULT=us-east-1
TARGET_ROOT_VOLUME_GB_DEFAULT=32
