TARGET_ARCH=x86_64
TARGET_EXECUTOR=aws-ssh
TARGET_AWS_ENV_PREFIX=AWS_X86
TARGET_SUPPORTS_SCHED_EXT=1
TARGET_NAME_TAG_DEFAULT=bpf-benchmark-x86
TARGET_INSTANCE_TYPE_DEFAULT=t3.micro
TARGET_TEST_INSTANCE_TYPE_DEFAULT=t3.micro
TARGET_BENCH_INSTANCE_TYPE_DEFAULT=t3.large
TARGET_REMOTE_USER_DEFAULT=ec2-user
TARGET_REMOTE_PYTHON_DEFAULT=python3
TARGET_REMOTE_STAGE_DIR_DEFAULT=/var/tmp/bpf-benchmark-aws-x86
TARGET_REMOTE_KERNEL_STAGE_DIR_DEFAULT=/var/tmp/codex-kernel-stage-x86
TARGET_AMI_PARAM_DEFAULT=/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64
TARGET_AWS_REGION_DEFAULT=us-east-1
TARGET_ROOT_VOLUME_GB_DEFAULT=32
TARGET_REMOTE_SWAP_SIZE_GB_DEFAULT=8
