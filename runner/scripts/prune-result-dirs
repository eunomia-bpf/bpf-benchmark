#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from collections import defaultdict
from pathlib import Path


def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Prune generated benchmark result directories.")
    parser.add_argument("--repo-root", required=True)
    parser.add_argument("--results-dir", required=True)
    parser.add_argument("--suite", required=True, choices=("corpus", "e2e"))
    parser.add_argument("--keep", required=True)
    return parser.parse_args()


def _keep_count(raw: str) -> int:
    text = raw.strip()
    if not text.isdigit():
        raise ValueError(f"KEEP_RESULTS must be a non-negative integer: {raw!r}")
    return int(text)


def _tracked_files(root: Path, run_dir: Path) -> str:
    rel = run_dir.relative_to(root)
    completed = subprocess.run(
        ["git", "-C", str(root), "ls-files", "--", f"{rel}/"],
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        sys.stderr.write(completed.stderr)
        raise SystemExit(completed.returncode)
    return completed.stdout.strip()


def main() -> int:
    args = _parse_args()
    try:
        keep = _keep_count(args.keep)
    except ValueError as exc:
        print(exc, file=sys.stderr)
        return 2

    root = Path(args.repo_root).resolve()
    results_dir = Path(args.results_dir).resolve()
    suite = args.suite.strip()
    if not results_dir.exists():
        return 0

    groups: dict[str, list[Path]] = defaultdict(list)
    for run_dir in results_dir.iterdir():
        if not run_dir.is_dir():
            continue
        metadata_path = run_dir / "metadata.json"
        if not metadata_path.is_file():
            continue
        metadata = json.loads(metadata_path.read_text())
        if str(metadata.get("suite", "")).strip() != suite:
            continue
        if _tracked_files(root, run_dir):
            continue
        run_type = str(metadata.get("run_type", "")).strip()
        if not run_type:
            print(f"result metadata is missing run_type: {metadata_path}", file=sys.stderr)
            return 1
        groups[run_type].append(run_dir)

    for run_type, paths in sorted(groups.items()):
        paths.sort(key=lambda path: (path.stat().st_mtime, path.name), reverse=True)
        for old_path in paths[keep:]:
            print(f"removing old {suite} result ({run_type}): {old_path}")
            shutil.rmtree(old_path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
