+	for (i = 0; i < tmp->aux->size_poke_tab; i++) {
+		struct bpf_map *map = tmp->aux->poke_tab[i].tail_call.map;
+
+		if (map->ops->map_poke_untrack)
+			map->ops->map_poke_untrack(map, tmp->aux);
+	}
